<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security: Enforce HTTPS only for all connections.
    Cleartext (HTTP) is already disabled via android:usesCleartextTraffic="false".
    This config provides an explicit security baseline and allows future
    certificate pinning if needed.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
