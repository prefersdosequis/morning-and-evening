<?xml version="1.0" encoding="utf-8"?>
<!--
    Security: Prevent data extraction on Android 12+ devices
    This prevents data from being extracted during device-to-device transfers
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Explicitly exclude app files from cloud backup -->
        <exclude domain="file" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Explicitly exclude app files from device-to-device transfer -->
        <exclude domain="file" path="." />
    </device-transfer>
</data-extraction-rules>





