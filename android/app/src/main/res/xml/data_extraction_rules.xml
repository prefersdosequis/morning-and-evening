<?xml version="1.0" encoding="utf-8"?>
<!--
    Security: Prevent data extraction on Android 12+ devices
    This prevents data from being extracted during device-to-device transfers
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Disable cloud backup -->
        <include domain="file" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Disable device-to-device transfer -->
        <include domain="file" path="." />
    </device-transfer>
</data-extraction-rules>





