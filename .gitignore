# Miscellaneous
*.class
*.log
*.pyc
*.mp3
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Audio assets are kept out of Git and injected during release builds.
/assets/audio/

# Local dev tools (do not commit binaries/venvs)
/tools/bin/
/tools/venv/
.semgrep_cache/
.semgrep/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
android/key.properties
android/local.properties

# Sensitive / local-only Android artifacts
**/*.jks
**/*.keystore
**/*.p12
**/*.pfx
**/*.hprof
android/bundletool-all.jar
android/devotions.json

